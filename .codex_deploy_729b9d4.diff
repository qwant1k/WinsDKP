+</head>
+<body>
+
+<header>
+  <div class="header-rune">⚔ Клан Трекер ⚔</div>
+  <h1>Legend of Ymir</h1>
+  <div class="subtitle">Журнал боссов — отслеживание респауна</div>
+  <div class="divider"><span class="divider-icon">☽</span></div>
+</header>
+
+<div class="container">
+  <div class="top-bar">
+    <button class="btn-add" onclick="openModal()">+ Добавить босса</button>
+  </div>
+
+  <div class="boss-header">
+    <div class="boss-header-cell">Босс / Локация</div>
+    <div class="boss-header-cell">Респаун</div>
+    <div class="boss-header-cell">Статус</div>
+    <div class="boss-header-cell">Таймер</div>
+    <div class="boss-header-cell"></div>
+  </div>
+
+  <div class="boss-list" id="bossList"></div>
+</div>
+
+<!-- Modal -->
+<div class="modal-overlay" id="modalOverlay">
+  <div class="modal">
+    <div class="modal-title">⚔ Новый Босс</div>
+    <div class="form-group">
+      <label class="form-label">Имя босса</label>
+      <input class="form-input" id="f-name" type="text" placeholder="Нидхёгг, Страж Бездны...">
+    </div>
+    <div class="form-group">
+      <label class="form-label">Локация</label>
+      <input class="form-input" id="f-location" type="text" placeholder="Долина Теней, Пещера Льда...">
+    </div>
+    <div class="form-group">
+      <label class="form-label">Иконка босса</label>
+      <div class="emoji-field-row">
+        <div style="position:relative;">
+          <button type="button" class="emoji-picker-btn" id="emojiBtn" onclick="toggleEmojiPicker()">🐉</button>
+          <div class="emoji-grid-popup" id="emojiGrid"></div>
+        </div>
+        <div style="font-size:13px;color:var(--text-dim);font-style:italic;padding-bottom:8px;">Нажми чтобы выбрать эмодзи</div>
+      </div>
+    </div>
+    <div class="form-group">
+      <label class="form-label">Время респауна</label>
+      <div class="form-row">
+        <div>
+          <label class="form-label">Часы</label>
+          <input class="form-input" id="f-hours" type="number" min="0" max="99" placeholder="0">
+        </div>
+        <div>
+          <label class="form-label">Минуты</label>
+          <input class="form-input" id="f-minutes" type="number" min="0" max="59" placeholder="30">
+        </div>
+        <div>
+          <label class="form-label">Секунды</label>
+          <input class="form-input" id="f-seconds" type="number" min="0" max="59" placeholder="0">
+        </div>
+      </div>
+    </div>
+    <div class="modal-actions">
+      <button class="btn-cancel" onclick="closeModal()">Отмена</button>
+      <button class="btn-submit" onclick="addBoss()">Добавить босса</button>
+    </div>
+  </div>
+</div>
+
+<div class="notif-container" id="notifContainer"></div>
+
+<script>
+  // Default bosses
+  let bosses = [
+    { id: 1, name: 'Нидхёгг Проклятый', location: 'Корни Иггдрасиля', respawnSeconds: 7200, killedAt: null, emoji: '🐉' },
+    { id: 2, name: 'Страж Бездны', location: 'Пещера Льда, Сектор 3', respawnSeconds: 3600, killedAt: null, emoji: '💀' },
+    { id: 3, name: 'Йормунганд', location: 'Берег Мёртвого Моря', respawnSeconds: 14400, killedAt: null, emoji: '🐍' },
+    { id: 4, name: 'Хримтурс', location: 'Замёрзшие Равнины', respawnSeconds: 1800, killedAt: null, emoji: '❄️' },
+  ];
+
+  let nextId = 5;
+
+  function formatRespawn(sec) {
+    const h = Math.floor(sec / 3600);
+    const m = Math.floor((sec % 3600) / 60);
+    const s = sec % 60;
+    if (h > 0) return `${h}ч ${m}м`;
+    if (m > 0) return `${m}м ${s > 0 ? s+'с' : ''}`;
+    return `${s}с`;
+  }
+
+  function getRemaining(boss) {
+    if (!boss.killedAt) return null;
+    const elapsed = Math.floor((Date.now() - boss.killedAt) / 1000);
+    const remaining = boss.respawnSeconds - elapsed;
+    return remaining > 0 ? remaining : 0;
+  }
+
+  function formatTimer(sec) {
+    const h = String(Math.floor(sec / 3600)).padStart(2, '0');
+    const m = String(Math.floor((sec % 3600) / 60)).padStart(2, '0');
+    const s = String(sec % 60).padStart(2, '0');
+    return { h, m, s };
+  }
+
+  function render() {
+    const list = document.getElementById('bossList');
+    if (bosses.length === 0) {
+      list.innerHTML = `<div class="empty-state"><div class="empty-icon">⚔️</div><div class="empty-text">Боссы не добавлены</div></div>`;
+      return;
+    }
+    list.innerHTML = bosses.map(boss => {
+      const remaining = getRemaining(boss);
+      const isDead = remaining !== null && remaining > 0;
+      const t = isDead ? formatTimer(remaining) : null;
+      return `
+      <div class="boss-row ${isDead ? 'dead' : ''}" id="row-${boss.id}">
+        <div class="boss-cell">
+          <div class="boss-name"><span class="boss-skull">${boss.emoji}</span>${boss.name}</div>
+          <div class="boss-location">📍 ${boss.location}</div>
+        </div>
+        <div class="boss-cell">
+          <div class="label">Респаун</div>
+          <div class="respawn-time">${formatRespawn(boss.respawnSeconds)}</div>
+        </div>
+        <div class="boss-cell status-cell">
+          ${isDead
+            ? `<span class="status-badge dead-badge"><span class="dot red"></span>Мёртв</span>`
+            : `<span class="status-badge alive"><span class="dot green"></span>Живой</span>`
+          }
+        </div>
+        <div class="boss-cell">
+          ${isDead
+            ? `<div class="label">Осталось</div><div class="timer-display" id="timer-${boss.id}">${t.h}:${t.m}:${t.s}</div>`
+            : `<div style="color:var(--text-dim);font-size:13px;font-style:italic;">—</div>`
+          }
+        </div>
+        <div class="boss-cell" style="padding:12px 16px;">
+          ${isDead
+            ? `<button class="btn-reset" onclick="resetBoss(${boss.id})">Отменить</button>`
+            : `<button class="btn-kill" onclick="killBoss(${boss.id})">☠ Убит</button>`
+          }
+        </div>
+
+        ${isDead ? `
+        <div class="timer-overlay">
+          <div>
+            <div class="timer-big">
+              <div class="timer-block"><span id="ot-h-${boss.id}">${t.h}</span><div style="font-size:9px;letter-spacing:2px;color:rgba(232,168,122,0.4);font-family:'Cinzel',serif;margin-top:2px;">ЧАСЫ</div></div>
+              <div class="timer-sep">:</div>
+              <div class="timer-block"><span id="ot-m-${boss.id}">${t.m}</span><div style="font-size:9px;letter-spacing:2px;color:rgba(232,168,122,0.4);font-family:'Cinzel',serif;margin-top:2px;">МИН</div></div>
+              <div class="timer-sep">:</div>
+              <div class="timer-block"><span id="ot-s-${boss.id}">${t.s}</span><div style="font-size:9px;letter-spacing:2px;color:rgba(232,168,122,0.4);font-family:'Cinzel',serif;margin-top:2px;">СЕК</div></div>
+            </div>
+            <div class="timer-label-big">${boss.name} — Ожидание респауна</div>
+          </div>
+        </div>` : ''}
+      </div>`;
+    }).join('');
+  }
+
+  function killBoss(id) {
+    const boss = bosses.find(b => b.id === id);
+    if (!boss) return;
+    boss.killedAt = Date.now();
+    render();
+    showNotif(`☠ ${boss.name} убит!`, `Таймер запущен. Босс возродится через ${formatRespawn(boss.respawnSeconds)}.`, 'dead');
+  }
+
+  function resetBoss(id) {
+    const boss = bosses.find(b => b.id === id);
+    if (!boss) return;
+    boss.killedAt = null;
+    render();
+  }
+
+  // Tick timers
+  setInterval(() => {
+    bosses.forEach(boss => {
+      const remaining = getRemaining(boss);
+      if (remaining === null) return;
+
+      if (remaining === 0) {
+        // Respawned
+        boss.killedAt = null;
+        render();
+        return;
+      }
+
+      const t = formatTimer(remaining);
+      const hEl = document.getElementById(`ot-h-${boss.id}`);
+      const mEl = document.getElementById(`ot-m-${boss.id}`);
+      const sEl = document.getElementById(`ot-s-${boss.id}`);
+      const tEl = document.getElementById(`timer-${boss.id}`);
+      if (hEl) hEl.textContent = t.h;
+      if (mEl) mEl.textContent = t.m;
+      if (sEl) sEl.textContent = t.s;
+      if (tEl) tEl.textContent = `${t.h}:${t.m}:${t.s}`;
+    });
+  }, 1000);
+
+  function showNotif(title, text, type) {
+    window.parent.postMessage({
+      type: 'boss-notification',
+      title,
+      text,
+      kind: type
+    }, '*');
+    return;
+
+    const c = document.getElementById('notifContainer');
+    const el = document.createElement('div');
+    el.className = 'notif';
+    el.style.borderColor = type === 'alive' ? 'var(--green)' : 'var(--red)';
+    el.style.borderLeftColor = type === 'alive' ? 'var(--green)' : 'var(--red)';
+    el.innerHTML = `<div class="notif-title" style="color:${type==='alive'?'var(--green)':'var(--red)'}">${title}</div><div>${text}</div>`;
+    c.appendChild(el);
+    setTimeout(() => el.remove(), 4200);
+
+    // Browser notification
+    if (Notification.permission === 'granted') {
+      new Notification(title, { body: text, icon: '⚔️' });
+    }
+  }
+
+  // Modal
+  function openModal() {
+    document.getElementById('modalOverlay').classList.add('open');
+  }
+  function closeModal() {
+    document.getElementById('modalOverlay').classList.remove('open');
+    document.getElementById('f-name').value = '';
+    document.getElementById('f-location').value = '';
+    document.getElementById('f-hours').value = '';
+    document.getElementById('f-minutes').value = '';
+    document.getElementById('f-seconds').value = '';
+    selectedEmoji = '🐉';
+    document.getElementById('emojiBtn').textContent = '🐉';
+  }
+
+  document.getElementById('modalOverlay').addEventListener('click', function(e) {
+    if (e.target === this) closeModal();
+  });
+
+  // Emoji picker
+  const allEmojis = [
+    '🐉','💀','🐍','❄️','🔥','⚡','👁️','🗡️','🛡️','☠️',
+    '🦇','🕷️','🦂','🐺','🦁','🐗','🐻','🦅',
+    '👹','👺','🤺','⚔️','🏹','🔱','💎','🌑',
+    '🌊','🌋','⛰️','🌪️','🌩️','🧿','🔮','💜',
+    '🧟','🧛','🧙','🦾','💥','🌀','🩸','⚰️'
+  ];
+
+  let selectedEmoji = '🐉';
+
+  function buildEmojiGrid() {
+    const grid = document.getElementById('emojiGrid');
+    grid.innerHTML = allEmojis.map(e => 
+      `<div class="emoji-option ${e === selectedEmoji ? 'selected' : ''}" onclick="selectEmoji('${e}')">${e}</div>`
+    ).join('');
+  }
+
+  function toggleEmojiPicker() {
+    const grid = document.getElementById('emojiGrid');
+    buildEmojiGrid();
+    grid.classList.toggle('show');
+  }
+
+  function selectEmoji(emoji) {
+    selectedEmoji = emoji;
+    document.getElementById('emojiBtn').textContent = emoji;
+    document.getElementById('emojiGrid').classList.remove('show');
+  }
+
+  // Close picker when clicking outside
+  document.addEventListener('click', function(e) {
+    if (!e.target.closest('#emojiBtn') && !e.target.closest('#emojiGrid')) {
+      document.getElementById('emojiGrid')?.classList.remove('show');
+    }
+  });
+
+  function addBoss() {
+    const name = document.getElementById('f-name').value.trim();
+    const location = document.getElementById('f-location').value.trim();
+    const h = parseInt(document.getElementById('f-hours').value) || 0;
+    const m = parseInt(document.getElementById('f-minutes').value) || 0;
+    const s = parseInt(document.getElementById('f-seconds').value) || 0;
+    const totalSeconds = h * 3600 + m * 60 + s;
+
+    if (!name) { alert('Введите имя босса'); return; }
+    if (totalSeconds === 0) { alert('Укажите время респауна'); return; }
+
+    bosses.push({
+      id: nextId++,
+      name,
+      location: location || 'Неизвестная локация',
+      respawnSeconds: totalSeconds,
+      killedAt: null,
+      emoji: selectedEmoji
+    });
+
+    closeModal();
+    render();
+
+    // Request notification permission
+    if (Notification.permission === 'default') {
+      Notification.requestPermission();
+    }
+  }
+
+  // External bridge for app integration (state sync, persistence)
+  window.__bossTrackerBridge = {
+    getState: function() {
+      return {
+        bosses: JSON.parse(JSON.stringify(bosses)),
+        nextId: nextId,
+      };
+    },
+    setState: function(state) {
+      if (!state || !Array.isArray(state.bosses) || typeof state.nextId !== 'number') return;
+      bosses = state.bosses.map(function(b) {
+        return {
+          id: Number(b.id),
+          name: String(b.name || ''),
+          location: String(b.location || ''),
+          respawnSeconds: Number(b.respawnSeconds || 0),
+          killedAt: b.killedAt === null ? null : Number(b.killedAt),
+          emoji: String(b.emoji || '🐉'),
+        };
+      });
+      nextId = Number(state.nextId);
+      render();
+    },
+    deleteBoss: function(id) {
+      bosses = bosses.filter(function(b) { return b.id !== id; });
+      render();
+    },
+  };
+
+  // Init
+  render();
+
+  // Ask for notification permission on load
+  if (Notification.permission === 'default') {
+    setTimeout(() => Notification.requestPermission(), 2000);
+  }
+</script>
+</body>
+</html>
