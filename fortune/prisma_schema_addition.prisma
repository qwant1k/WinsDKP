// 1. Добавить поле в модель WarehouseItem:
//    availableInFortune Boolean @default(false)

// 2. Добавить новую модель:

model FortuneSpin {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  clanId       String
  bet          Int      // 15 | 30 | 50 | 100
  wonItemId    String?
  wonItem      WarehouseItem? @relation(fields: [wonItemId], references: [id])
  wonRarity    String?  // COMMON | UNCOMMON | RARE | EPIC | LEGENDARY
  dkpSpent     Int
  spinHash     String   // SHA-256 proof of fairness
  seed         String   // random seed
  createdAt    DateTime @default(now())

  @@map("fortune_spins")
}

