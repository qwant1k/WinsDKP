// 1. В enum DkpTransactionType добавить:
//    SLOT_BET
//    SLOT_WIN

// 2. Добавить модель:

model SlotSpin {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  clanId     String
  tier       String   // bronze | silver | gold | emerald | diamond | arcane
  multiplier Float
  payout     Float    // DKP paid out
  seed       String
  spinHash   String
  createdAt  DateTime @default(now())

  @@map("slot_spins")
  @@index([clanId, createdAt(sort: Desc)])
}

